@page "/tasks/delete"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using TodoApp.Models
@using TodoApp.Services
@attribute [Authorize]
@inject ITaskService TaskService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

@code {
    [SupplyParameterFromForm(FormName = "delete")]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (HttpMethods.IsPost(NavigationManager.Uri))
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

            if (!string.IsNullOrEmpty(userId))
            {
                await TaskService.DeleteTaskAsync(Id, userId);
            }
            NavigationManager.NavigateTo("/tasks");
        }
        else
        {
            NavigationManager.NavigateTo("/tasks");
        }
    }
}
