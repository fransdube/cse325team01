@page "/tasks/toggle"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using TodoApp.Models
@using TodoApp.Services
@attribute [Authorize]
@inject ITaskService TaskService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

@code {
    [SupplyParameterFromForm(FormName = "toggle")]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine($"[DEBUG] Toggle.razor initialized. Id={Id}");
        if (Id > 0)
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

            if (!string.IsNullOrEmpty(userId))
            {
                await TaskService.ToggleTaskCompletionAsync(Id, userId);
            }
        }
        NavigationManager.NavigateTo("/tasks");
    }
}
